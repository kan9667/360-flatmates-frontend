# Required: Environment (dev, staging, prod)
APP_ENV=dev
# Required: Your backend API URL (e.g., https://api.360ghar.com/api/v1).
# For physical Android USB development, prefer:
#   .\scripts\run_android_usb.ps1
# The helper uses adb reverse and passes:
#   API_BASE_URL=http://127.0.0.1:3600/api/v1
# This avoids stale machine-specific LAN IPs in .env.
API_BASE_URL=https://api.360ghar.com/api/v1
# Required: Your Supabase project URL (e.g., https://xxxxx.supabase.co)
SUPABASE_URL=
# Required: Your Supabase anon/public key
SUPABASE_PUBLISHABLE_KEY=
# Optional: debug logging
ENABLE_DEBUG_LOGS=true
# Optional: Google Places API key for location search autocomplete
GOOGLE_PLACES_API_KEY=
